---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const patterns = await getCollection('patterns');
  return patterns.map(pattern => ({
    params: { slug: pattern.slug },
    props: { pattern },
  }));
}

const { pattern } = Astro.props;
const { Content } = await pattern.render();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pattern.data.title} | Arpit Maheshwari</title>
  <meta name="description" content={pattern.data.description}>
  <meta property="og:title" content={pattern.data.title}>
  <meta property="og:description" content={pattern.data.description}>
  <meta property="og:url" content={Astro.url}>
  <meta property="og:type" content="article">
  <link rel="canonical" href={Astro.url}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Mono:wght@300;400&family=Inter:wght@300;400;500;600;700&family=Lexend:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-PFY6ME99K8"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-PFY6ME99K8');
  </script>
  <style>
    :root {
      --bg: #0A0A0A;
      --ink: #F2EDE4;
      --ink-muted: rgba(242, 237, 228, 0.5);
      --ink-dim: rgba(242, 237, 228, 0.25);
      --gold: #D4A85E;
      --border: rgba(255, 255, 255, 0.07);
      --ff-display: 'Cormorant Garamond', Georgia, serif;
      --ff-sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --ff-mono: 'DM Mono', monospace;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--ink);
      font-family: var(--ff-sans);
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--gold); text-decoration: underline; }
    a:hover { color: #E8C88A; }

    article {
      max-width: 800px;
      margin: 0 auto;
      padding: 120px 48px;
    }

    article h1 {
      font-family: var(--ff-display);
      font-size: clamp(36px, 4vw, 54px);
      font-weight: 300;
      line-height: 1.15;
      margin-bottom: 32px;
      color: var(--ink);
    }

    article h2, article h3 {
      font-family: var(--ff-display);
      font-size: clamp(20px, 3vw, 32px);
      font-weight: 400;
      line-height: 1.3;
      margin-top: 48px;
      margin-bottom: 24px;
      color: var(--ink);
    }

    article p {
      margin-bottom: 20px;
      color: var(--ink-muted);
      line-height: 1.8;
    }

    article table {
      width: 100%;
      margin: 32px 0;
      border-collapse: collapse;
      border: 1px solid var(--border);
    }

    article th, article td {
      padding: 12px;
      text-align: left;
      border-bottom: 1px solid var(--border);
      font-size: 13px;
    }

    article th {
      background: rgba(212, 168, 94, 0.05);
      color: var(--gold);
      font-weight: 600;
    }

    article code {
      background: rgba(255, 255, 255, 0.02);
      padding: 2px 6px;
      border-radius: 2px;
      font-family: var(--ff-mono);
      font-size: 13px;
      color: #E8C88A;
    }

    article blockquote {
      border-left: 2px solid var(--gold);
      padding-left: 24px;
      margin: 24px 0;
      color: var(--ink-muted);
      font-style: italic;
    }

    article ul, article ol {
      margin: 24px 0 24px 32px;
    }

    article li {
      margin-bottom: 12px;
    }

    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 24px 48px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      background: rgba(10, 10, 10, 0.6);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
    }

    .nav-back {
      font-family: var(--ff-mono);
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .nav-back:hover { color: #E8C88A; }

    @media (max-width: 768px) {
      article { padding: 80px 24px; }
      nav { padding: 16px 24px; }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-back">← Back to portfolio</a>
  </nav>

  <article>
    <h1>{pattern.data.title}</h1>
    <Content />
  </article>
</body>
</html>
